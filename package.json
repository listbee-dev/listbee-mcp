{
  "name": "listbee-mcp",
  "version": "0.1.0",
  "description": "MCP server for ListBee — commerce API for AI agents",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "listbee-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "mcp-tools.yaml"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "generate": "tsx scripts/generate.ts",
    "generate:check": "tsx scripts/generate.ts --check",
    "build": "npm run generate && tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "npm run generate:check && tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "yaml": "2.8.3",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.19.17",
    "json-schema-to-zod": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/listbee-dev/listbee-mcp.git"
  },
  "homepage": "https://listbee.so",
  "keywords": [
    "mcp",
    "listbee",
    "commerce",
    "ai-agents",
    "model-context-protocol"
  ]
}
